# ============================================================
# GitHub Actions Runner Orchestrator — Configuration
# ============================================================
# Copy this file to /opt/gh-runner/config/config.env and fill in the values.
# This file is chmod 600 (root-readable only) because it contains secrets.
# ============================================================

# ------------------------------------------------------------
# GitHub Authentication
# ------------------------------------------------------------
# Use a fine-grained Personal Access Token (not a classic PAT).
# Create one at: Settings → Developer settings → Personal access tokens → Fine-grained tokens
#
# The orchestrator only needs two permissions on the target repository:
#   - Actions:          Read-only       (poll for queued workflow runs)
#   - Self-hosted runners: Read and write  (generate JIT runner tokens)
#
# Nothing else. CI jobs get their own separate GITHUB_TOKEN from GitHub
# Actions automatically, so release uploads, artifact uploads, and repo
# checkout all use that token — not this one.
GITHUB_TOKEN=github_pat_REPLACE_ME

# ------------------------------------------------------------
# Repository targeting
# ------------------------------------------------------------
GITHUB_OWNER=your-username-or-org
GITHUB_REPO=your-repository-name

# ------------------------------------------------------------
# Runner registration
# ------------------------------------------------------------
# Comma-separated labels applied to every runner registered by this host.
# Workflows select runners with: runs-on: [self-hosted, macOS, x64]
# Add custom labels (e.g. "gpu", "large") to target specific machines.
RUNNER_LABELS=self-hosted,macOS,x64

# Runner group ID (1 = Default group). Create custom groups in:
# GitHub → Settings → Actions → Runner groups
RUNNER_GROUP_ID=1

# ------------------------------------------------------------
# Concurrency and safety limits
# ------------------------------------------------------------
# Maximum number of jobs running simultaneously on this machine.
# Each job creates one macOS user. Keep this ≤ CPU core count.
MAX_CONCURRENT_JOBS=3

# Kill the runner process if a job exceeds this many seconds (default: 1 hour).
JOB_TIMEOUT_SECONDS=3600

# How often (seconds) to poll GitHub API for queued workflow runs.
# Lower values = faster job pickup, more API calls.
# GitHub rate limit: 5000 requests/hour for PAT (15s interval ≈ 240 calls/hour).
POLL_INTERVAL_SECONDS=15

# ------------------------------------------------------------
# Runner binary download URL (required)
# ------------------------------------------------------------
# Full URL to the .tar.gz for your platform from:
#   https://github.com/actions/runner/releases
#
# Examples:
#   Apple Silicon:  actions-runner-osx-arm64-X.Y.Z.tar.gz
#   Intel:          actions-runner-osx-x64-X.Y.Z.tar.gz
#
# The checksum file is fetched automatically from the same release.
# To upgrade: update this URL and delete runner-template/, then restart.
RUNNER_DOWNLOAD_URL=https://github.com/actions/runner/releases/download/vX.Y.Z/actions-runner-osx-arm64-X.Y.Z.tar.gz

# ------------------------------------------------------------
# GitHub API endpoint
# ------------------------------------------------------------
# Change for GitHub Enterprise Server, e.g.:
#   GITHUB_API_URL=https://github.example.com/api/v3
GITHUB_API_URL=https://api.github.com
